{
	"name": "podoba",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.14",
	"description": "podoba — the universal design system. React Aria Components + Tailwind, seeded from graphic-standard's @app/ui. App-agnostic: consumed by GS, pramen, and everything future.",
	"workspaces": {
		"packages": ["packages/*"],
		"catalog": {
			"typescript": "^5.9.3",
			"@types/bun": "^1.3.3"
		},
		"catalogs": {
			"ui": {
				"react": "^19.2.1",
				"react-dom": "^19.2.1",
				"@types/react": "^19.2.7",
				"@types/react-dom": "^19.2.3",
				"react-aria-components": "1.18.0",
				"class-variance-authority": "0.7.1",
				"clsx": "2.1.1",
				"tailwind-merge": "3.6.0",
				"@radix-ui/react-slot": "1.2.4",
				"tailwindcss": "3.4.19",
				"@tailwindcss/typography": "0.5.19"
			}
		}
	},
	"scripts": {
		"typecheck": "tsc --build",
		"version:bump": "bun scripts/version.ts",
		"publish:packages": "bun scripts/publish.ts"
	},
	"devDependencies": {
		"typescript": "catalog:"
	}
}
