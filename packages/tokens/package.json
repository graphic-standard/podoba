{
	"name": "@podoba/tokens",
	"version": "0.0.16",
	"type": "module",
	"description": "podoba design tokens — static DTCG tokens.json + generated CSS custom properties. Framework-agnostic.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/graphic-standard/podoba.git",
		"directory": "packages/tokens"
	},
	"homepage": "https://github.com/graphic-standard/podoba#readme",
	"bugs": "https://github.com/graphic-standard/podoba/issues",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./variables.css": "./src/variables.css",
		"./fonts.css": "./src/fonts.css",
		"./tokens.json": "./src/tokens.json"
	},
	"files": ["src"],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"typecheck": "tsc --build"
	},
	"devDependencies": {
		"typescript": "catalog:",
		"@types/bun": "catalog:"
	}
}
