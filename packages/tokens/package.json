		"./tokens.json": "./src/tokens.json"
	},
	"files": ["src"],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"typecheck": "tsc --build"
	},
	"devDependencies": {
		"typescript": "catalog:",
		"@types/bun": "catalog:"
	}
}
